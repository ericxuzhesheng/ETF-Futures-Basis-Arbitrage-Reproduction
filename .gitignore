# Secrets — NEVER commit the tushare token
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Local data cache (re-fetchable from tushare)
data/*.parquet
data/*.csv

# Self-recorded L2 snapshots (Track A) — large, recorded locally
data/snapshots/

# Re-generable Track A child-order fills can become large with L2 data.
results/trackA_execution_fills_*.csv

# Hummingbot (Track B) runtime — logs/data/secrets generated in the container
trackB_deploy/hummingbot/logs/
trackB_deploy/hummingbot/data/

# OS / editor
.DS_Store
.idea/
.vscode/

# LaTeX build artifacts (keep report.tex + report.pdf)
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
report/*.xdv
